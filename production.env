APP_NAME="The Pro Shop at the HSC"
APP_TITLE="The Pro Shop at the HSC"
APP_ENV=production
APP_KEY=
APP_DEBUG=true
APP_LOG_LEVEL=debug
APP_URL=https://hscshop.co.za
APP_LOCALE=en
APP_TIMEZONE="Africa/Johannesburg"

ADMINISTRATOR_USERNAMES=
ALLOW_REGISTRATION=false

LOG_CHANNEL=stack

